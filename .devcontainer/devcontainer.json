{
  "name": "@Kakoolnews",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "postAttachCommand": {
    "public": "gh codespace ports visibility 80:public -c $CODESPACE_NAME",
    "xray": "sudo -E SERVER_IP=YOUR_VPS_IP /usr/local/bin/entrypoint.sh"
  },
  "portsAttributes": {
    "80": {
      "label": "xray-vless",
      "protocol": "http",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [80],
  "hostRequirements": {
    "cpus": 1
  },
  "customizations": {
    "codespaces": {
      "secrets": {
        "SERVER_IP": {
          "description": "Your VPS IP address"
        }
      }
    }
  }
}
